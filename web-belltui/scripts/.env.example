# === 3D Asset Generation Pipeline ===
# 사용할 API 제공자 선택: meshy | tripo
ASSET_PROVIDER=meshy

# Meshy AI API Key (https://app.meshy.ai → Settings → API)
MESHY_API_KEY=your_meshy_key_here

# Tripo AI API Key (https://www.tripo3d.ai → Developer → API)
TRIPO_API_KEY=your_tripo_key_here

# 동시 생성 요청 수 (API rate limit 고려)
MAX_CONCURRENT=3

# 폴링 간격 (밀리초)
POLL_INTERVAL_MS=5000

# Blender 실행 경로 (최적화 스크립트용, 비어있으면 최적화 스킵)
BLENDER_PATH=
